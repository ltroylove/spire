# GitHub Webhook Secret (required for production webhook signature verification)
# Set this to the secret configured in your GitHub webhook settings.
# Leave empty to disable verification (not recommended in production).
QUEST_API_WEBHOOK_SECRET=

# Sentry Error Tracking (optional - leave empty to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_DEBUG=false
